meta {
  name: Reset Password
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/2/account/reset-password
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "user@example.com",
    "turnstileResponse": ""
  }
}

docs {
  Initiate a password reset. Sends a reset email if the address is associated with an account. (V2)
}

meta {
  name: Change Email
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/1/account/email
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "user@example.com"
  }
}

docs {
  Change the email address of the authenticated user. Sends a verification email to the new address.
}
